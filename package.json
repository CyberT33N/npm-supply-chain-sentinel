{
  "name": "npm-supply-chain-sentinel",
  "version": "0.1.0",
  "description": "Cross-platform Node.js scanner for detecting documented npm supply-chain compromises, persistence artifacts, malicious install hooks, campaign IOCs, and PNPM 11 Fortress governance drift across projects or entire hosts.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "bin": {
    "npm-supply-chain-sentinel": "./src/cli/scan-supply-chain-campaigns.mjs",
    "npm-supply-chain-sentinel-pnpm-governance": "./src/cli/scan-pnpm-governance.mjs"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.16.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.2.2",
      "onFail": "error"
    }
  },
  "scripts": {
    "scan": "node ./src/cli/scan-supply-chain-campaigns.mjs",
    "scan:project": "node ./src/cli/scan-supply-chain-campaigns.mjs",
    "scan:project:verbose": "node ./src/cli/scan-supply-chain-campaigns.mjs",
    "scan:machine-wide": "node ./src/cli/scan-supply-chain-campaigns.mjs --machine-wide",
    "scan:machine-wide:verbose": "node ./src/cli/scan-supply-chain-campaigns.mjs --machine-wide",
    "scan:no-home": "node ./src/cli/scan-supply-chain-campaigns.mjs --no-home",
    "scan:blocklists": "node ./src/cli/scan-supply-chain-campaigns.mjs --write-blocklists ./docs/security/blocklists",
    "scan:json": "node ./src/cli/scan-supply-chain-campaigns.mjs --json ./generated/latest-scan.json",
    "scan:apply-hosts": "node ./src/cli/scan-supply-chain-campaigns.mjs --apply-hosts",
    "scan:apply-firewall": "node ./src/cli/scan-supply-chain-campaigns.mjs --apply-firewall",
    "scan:machine-wide:full": "node ./src/cli/scan-supply-chain-campaigns.mjs --machine-wide --apply-hosts --apply-firewall",
    "scan:machine-wide:full:heartbeat-5s": "node ./src/cli/scan-supply-chain-campaigns.mjs --machine-wide --heartbeat-sec 5 --apply-hosts --apply-firewall",
    "scan:machine-wide:fast-preflight": "node ./src/cli/scan-supply-chain-campaigns.mjs --machine-wide --fast-preflight",
    "scan:pnpm-governance": "node ./src/cli/scan-pnpm-governance.mjs",
    "scan:pnpm-governance:json": "node ./src/cli/scan-pnpm-governance.mjs --json ./generated/latest-pnpm-governance-scan.json",
    "scan:pnpm-governance:help": "node ./src/cli/scan-pnpm-governance.mjs --help",
    "scan:quiet": "node ./src/cli/scan-supply-chain-campaigns.mjs --quiet",
    "scan:help": "node ./src/cli/scan-supply-chain-campaigns.mjs --help"
  },
  "keywords": [
    "security",
    "supply-chain",
    "npm",
    "nodejs",
    "incident-response",
    "threat-hunting",
    "ioc"
  ],
  "dependencies": {
    "minimatch": "catalog:",
    "semver": "catalog:",
    "yaml": "catalog:"
  }
}
