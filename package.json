{
  "name": "npm-supply-chain-sentinel",
  "version": "0.1.0",
  "description": "Cross-platform Node.js scanner for detecting documented npm supply-chain compromises, persistence artifacts, malicious install hooks, campaign IOCs, and PNPM 11 Fortress governance drift across projects or entire hosts.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "bin": {
    "npm-supply-chain-sentinel": "./bin/npm-supply-chain-sentinel.js",
    "npm-supply-chain-sentinel-pnpm-governance": "./bin/npm-supply-chain-sentinel-pnpm-governance.js"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26.2.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.2.2",
      "onFail": "error"
    }
  },
  "scripts": {
    "test": "vitest run --config ./vitest.config.ts",
    "check:types": "tsc -b ./tsconfig.json",
    "scan": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts",
    "scan:project": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts",
    "scan:project:verbose": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts",
    "scan:machine-wide": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --machine-wide",
    "scan:machine-wide:verbose": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --machine-wide",
    "scan:no-home": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --no-home",
    "scan:blocklists": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --write-blocklists ./docs/security/blocklists",
    "scan:json": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --json ./generated/latest-scan.json",
    "scan:apply-hosts": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --apply-hosts",
    "scan:apply-firewall": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --apply-firewall",
    "scan:machine-wide:full": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --machine-wide --apply-hosts --apply-firewall",
    "scan:machine-wide:full:heartbeat-5s": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --machine-wide --heartbeat-sec 5 --apply-hosts --apply-firewall",
    "scan:machine-wide:fast-preflight": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --machine-wide --fast-preflight",
    "scan:pnpm-governance": "node --import tsx ./src/cli/scan-pnpm-governance.ts",
    "scan:pnpm-governance:json": "node --import tsx ./src/cli/scan-pnpm-governance.ts --json ./generated/latest-pnpm-governance-scan.json",
    "scan:pnpm-governance:help": "node --import tsx ./src/cli/scan-pnpm-governance.ts --help",
    "scan:quiet": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --quiet",
    "scan:help": "node --import tsx ./src/cli/scan-supply-chain-campaigns.ts --help",
    "typecheck": "tsc -p ./tsconfig.node.json"
  },
  "keywords": [
    "security",
    "supply-chain",
    "npm",
    "nodejs",
    "incident-response",
    "threat-hunting",
    "ioc"
  ],
  "dependencies": {
    "minimatch": "catalog:",
    "semver": "catalog:",
    "tsx": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@sindresorhus/is": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "dotenv": "catalog:",
    "jest-extended": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  }
}
